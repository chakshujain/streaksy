PORT=3001
NODE_ENV=production

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/streaksy

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Frontend URL (used for CORS, email links, etc.)
FRONTEND_URL=http://streaksy.in
ALLOWED_ORIGINS=http://streaksy.in,http://www.streaksy.in

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://streaksy.in/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://streaksy.in/api/auth/github/callback

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Streaksy <noreply@streaksy.in>

# AI (NVIDIA NIM)
NVIDIA_API_KEY=
AI_MODEL=meta/llama-3.3-70b-instruct
AI_BASE_URL=https://integrate.api.nvidia.com/v1

# Web Push (VAPID) – generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@streaksy.in

# Logging
LOG_LEVEL=info
