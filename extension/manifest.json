{
  "manifest_version": 3,
  "name": "Streaksy — LeetCode Sync",
  "version": "1.0.0",
  "description": "Automatically sync your LeetCode submissions to Streaksy.",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": ["https://leetcode.com/*", "https://streaksy.in/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}
